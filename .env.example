# === Wallet & Network ===
PRIVATE_KEY=

WALLET_ADDRESS=

# === Floe Borrowing Settings ===
# Use "1" for the main USDC pilot market on Base
MARKET_ID=1

# Amounts in raw units (e.g., 6 decimals for USDC, 18 for WETH)
BORROW_AMOUNT=1000000000                  # 1,000 USDC
COLLATERAL_AMOUNT=1000000000000000000     # 1 WETH
MAX_INTEREST_RATE_BPS=1500                # max 15% APR
DURATION=2592000                          # 30 days in seconds

# Optional: Custom Base RPC URL
# BASE_RPC_URL=https://mainnet.base.org
