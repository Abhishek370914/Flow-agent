# Floe Credit Agent Environment Variables
# Copy this file to .env and fill in your values

# 0x... (66 characters including 0x)
PRIVATE_KEY= Enter your private key

# 0x... (42 characters including 0x)
WALLET_ADDRESS= Wallet WALLET_ADDRESS 

# Optional: Custom Base RPC URL (default is https://mainnet.base.org)
# BASE_RPC_URL=https://mainnet.base.org
